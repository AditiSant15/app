<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="200dp"
    android:layout_margin="4dp"
    android:background="#ffffff"
    app:cardCornerRadius="10dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:id="@+id/llFavContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:weightSum="13">

        <ImageView
            android:id="@+id/imgFavMovieImage"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="5"
            android:background="#f5f5f5"
            android:scaleType="fitCenter"
            android:src="@drawable/default_image"/>

        <TextView
            android:id="@+id/txtFavMovieTitle"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="2"
            android:gravity="center"
            android:text="Hello World"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/txtFavMovieAuthor"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="2"
            android:gravity="center"
            android:text="Author Name"
            android:textColor="#555555"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/txtFavMoviePrice"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="2"
            android:gravity="center"
            android:text="Rs.160"
            android:textColor="#000000"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/txtFavMovieRating"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="2"
            android:gravity="center"
            android:text="4.5"
            android:textColor="#ffc828"
            android:textSize="14sp"
            android:textStyle="bold"
            android:drawableStart="@drawable/ic_ratings"
            android:drawablePadding="4dp"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>